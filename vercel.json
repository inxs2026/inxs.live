{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    {
      "src": "api/proxy.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "10mb" }
    }
  ],
  "routes": [
    { "src": "/api/proxy", "dest": "/api/proxy.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "functions": {
    "api/proxy.py": {
      "maxDuration": 30
    }
  }
}
